#adapted from Félix-antoine Trifiro's pipeline
""" 
This pipeline performs all step of  a proteomics analysis from raw file to the
proteins identification with ProteinProphet. It also perform FDR control evaluation with FDRBench

N.B. The transproteomic pipeline (TPP) needs to be installed and added to PATH.

It can be runned via the following command:
    # snakemake --cores 12 --use-singularity --resources mem_gb=64 --use-conda
snakemake --cores 12 --use-singularity --use-conda --singularity-args "-B /project/def-marie87/glaudea/FDRbench_pipeline"
NOTE: convert_raw rule has been marked as using 16 GB of ram, but this greatly
      varies depending of the dataset. 
"""
configfile: "../config/config.yaml"




