    input:
#        c_FDR = ["results/{dataset}/ms_fragger/FDP/{sample}/canonical_FDR_fdrbench.txt"],
#        nc_FDR = ["results/{dataset}/ms_fragger/FDP/{sample}/nc_FDR_fdrbench.txt"],
