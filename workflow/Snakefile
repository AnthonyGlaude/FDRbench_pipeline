        c_FDR = expand("results/{dataset}/ms_fragger/FDP/{sample}/can_FDR_fdrbench_{seed}.txt", seed=config["path"]["seeds"], allow_missing=True),
        nc_FDR = expand("results/{dataset}/ms_fragger/FDP/{sample}/nc_FDR_fdrbench_{seed}.txt", seed=config["path"]["seeds"], allow_missing=True),
        entrapment_pep=expand("results/database/{dataset}/{dataset}_{seed}_entrapment_pep.pkl",  seed=config["path"]["seeds"], allow_missing=True),
        prophet = "results/{dataset}/ms_fragger/search/{sample}/{sample}_prophet.pepXML",
        check_prot= "results/database/{dataset}/{dataset}_1_check_prot.pkl",
    output:
        can_final = "results/{dataset}/ms_fragger/final/{sample}/canonical_final.tsv",
        nc_final = "results/{dataset}/ms_fragger/final/{sample}/nc_final.tsv"
    params:
        outpath = "results/{dataset}/ms_fragger/final/{sample}/",
        seeds = config["path"]["seeds"]
    log:
        "logs/{dataset}/{sample}/FINAL.log"
    conda:
        "../envs/fdrbench.yml"
    script:
        "scripts/final_filtration.py"
