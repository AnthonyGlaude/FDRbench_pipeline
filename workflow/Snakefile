rule pickles:
    "Make a pkl of canonical and non canonical peptide from the entrapment database"
    input:
        entrapment = rules.decoys_ent_db.output.fasta_entrapment_search_decoys_db,
        search=rules.decoys_db.output.fasta_search_decoys_db
    output:
        check_prot="results/database/{dataset}/{dataset}_{seed}_check_prot.pkl",
        entrapment_pep="results/database/{dataset}/{dataset}_{seed}_entrapment_pep.pkl",
    params:
        outpath="results/database/{dataset}/{dataset}_{seed}_"
    log:
        "logs/{dataset}/database/pickles_{seed}.log"
    conda:
        "../envs/fdrbench.yml"
    script:
        "scripts/pickles.py"

rule convert_xml_tsv:
    """ Convert xml output from Prophet to tsv """
    input:
        pepxml="results/{dataset}/ms_fragger/msfragger_entrapment_search_{seed}/{sample}/{sample}_entrapment_prophet.pepXML",
        check_prot = rules.pickles.output.check_prot
    output:
        c_tsv="results/{dataset}/ms_fragger/msfragger_entrapment_search_{seed}/{sample}/canonicals.tsv",
        nc_tsv="results/{dataset}/ms_fragger/msfragger_entrapment_search_{seed}/{sample}/non_canonicals.tsv"
    params:
        outpath="results/{dataset}/ms_fragger/msfragger_entrapment_search_{seed}/{sample}/"
    log:
        "logs/{dataset}/convert/convert_xml_{dataset}_{sample}_{seed}.log"
    conda:
        "../envs/fdrbench.yml"
    script:
        "scripts/tsvs_for_FDR.py"



rule convert_xml_tsv_search:
    """sortir les psms et leur q_value"""
    input:
        pepxml="results/{dataset}/ms_fragger/search/{sample}/{sample}_prophet.pepXML",
        check_prot ="results/database/{dataset}/{dataset}_1_check_prot.pkl"
    output:
        c_psm="results/{dataset}/ms_fragger/search/{sample}/canonicals_psm.tsv",
        nc_psm="results/{dataset}/ms_fragger/search/{sample}/non_canonicals_psm.tsv"
    params:
        outpath="results/{dataset}/ms_fragger/search/{sample}/"
    log:
        "logs/{dataset}/convert/convert_xml_search_{dataset}_{sample}.log"
    conda:
        "../envs/fdrbench.yml"
    script:
        "scripts/tsvs_for_FDR_search.py"



rule calculate_fdp:
    " Run FDRbench on the percolator output to estimate FDP "
    input:
        c_tsv="results/{dataset}/ms_fragger/msfragger_entrapment_search_{seed}/{sample}/canonicals.tsv",
        nc_tsv="results/{dataset}/ms_fragger/msfragger_entrapment_search_{seed}/{sample}/non_canonicals.tsv",
        pairs="results/database/{dataset}/{dataset}_FDR_entrapment_{seed}.txt"
    output:
        c_fdp="results/{dataset}/ms_fragger/FDP/{sample}/can_FDR_fdrbench_{seed}.txt",
        nc_fdp="results/{dataset}/ms_fragger/FDP/{sample}/nc_FDR_fdrbench_{seed}.txt"
    params:
        fdrbench=config["path"]["fdrbench"]
    log:
        "logs/{dataset}/{sample}/FDP_{seed}.log"
    shell:
        "(java -jar {params.fdrbench} "
        "-i {input.c_tsv} "
        "-fold 1 "
        "-pep {input.pairs} "
        "-level peptide "
        "-o {output.c_fdp}) &> {log} ; "

        "(java -jar {params.fdrbench} "
        "-i {input.nc_tsv} "
        "-fold 1 "
        "-pep {input.pairs} "
        "-level peptide "
        "-o {output.nc_fdp}) &>> {log}"

